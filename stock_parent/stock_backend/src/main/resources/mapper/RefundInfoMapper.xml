<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ys.stock.mapper.RefundInfoMapper">

    <resultMap id="BaseResultMap" type="com.ys.stock.pojo.RefundInfo">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="orderNo" column="order_no" jdbcType="VARCHAR"/>
        <result property="refundNo" column="refund_no" jdbcType="VARCHAR"/>
        <result property="refundId" column="refund_id" jdbcType="VARCHAR"/>
        <result property="totalFee" column="total_fee" jdbcType="INTEGER"/>
        <result property="refund" column="refund" jdbcType="INTEGER"/>
        <result property="reason" column="reason" jdbcType="VARCHAR"/>
        <result property="refundStatus" column="refund_status" jdbcType="VARCHAR"/>
        <result property="contentReturn" column="content_return" jdbcType="VARCHAR"/>
        <result property="contentNotify" column="content_notify" jdbcType="VARCHAR"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id
        ,order_no,refund_no,
        refund_id,total_fee,refund,
        reason,refund_status,content_return,
        content_notify,create_time,update_time
    </sql>
    <insert id="insert" parameterType="com.ys.stock.pojo.RefundInfo" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_refund_info (order_no, refund_no,
                                   refund_id, total_fee, refund,
                                   reason, refund_status, content_return,
                                   content_notify, create_time, update_time)
        VALUES (#{orderNo}, #{refundNo}, #{refundId}, #{totalFee}, #{refund}, #{reason}, #{refundStatus},
                #{contentReturn}, #{contentNotify}, #{createTime}, #{updateTime})
    </insert>

    <update id="update">
        update t_refund_info set content_return =#{content} ,refund_status =#{refundStatus} where refund_no =#{refundNo}
    </update>
    <select id="select" resultType="com.ys.stock.pojo.RefundInfo">
        select * from t_refund_info where order_no = #{orderNo}
    </select>
</mapper>
