<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ys.stock.mapper.PaymentInfoMapper">

    <resultMap id="BaseResultMap" type="com.ys.stock.pojo.PaymentInfo">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="orderNo" column="order_no" jdbcType="VARCHAR"/>
        <result property="transactionId" column="transaction_id" jdbcType="VARCHAR"/>
        <result property="paymentType" column="payment_type" jdbcType="VARCHAR"/>
        <result property="tradeType" column="trade_type" jdbcType="VARCHAR"/>
        <result property="tradeState" column="trade_state" jdbcType="VARCHAR"/>
        <result property="payerTotal" column="payer_total" jdbcType="INTEGER"/>
        <result property="content" column="content" jdbcType="VARCHAR"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id
        ,order_no,transaction_id,
        payment_type,trade_type,trade_state,
        payer_total,content,create_time,
        update_time
    </sql>
    <insert id="insert" parameterType="com.ys.stock.pojo.PaymentInfo">
        INSERT INTO t_payment_info (id, order_no, transaction_id, payment_type,trade_type, trade_state, payer_total, content,
                                    create_time, update_time)
        values (#{id}, #{orderNo}, #{transactionId}, #{paymentType},#{tradeType}, #{tradeState}, #{payerTotal}, #{content},
                #{createTime}, #{updateTime})
    </insert>
</mapper>
